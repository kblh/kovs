<nav class="shadow-md mb-8 relative z-50">
  <div class="max-w-md m-auto px-4 py-4">
    <ul class="flex flex-wrap gap-4 items-center">
      <li>
        <a href="{{ baseUrl }}/" class="text-navigation hover:text-navigation-hover transition-colors {% if page.url == '/' %}text-navigation-active font-bold{% endif %}">
          Domů
        </a>
      </li>
      {% if collections.koncerty %}
        <li>
          <a href="{{ baseUrl }}/koncerty/" class="text-navigation hover:text-navigation-hover transition-colors {% if page.url == '/koncerty/' %}text-navigation-active font-bold{% endif %}">
            Koncerty
          </a>
        </li>
      {% endif %}
      {% if collections.pages %}
        {% for navPage in collections.pages %}
          <li>
            <a href="{{ baseUrl }}{{ navPage.url }}" class="text-navigation hover:text-navigation-hover transition-colors {% if navPage.url == page.url %}text-navigation-active font-bold{% endif %}">
              {{ navPage.data.title }}
            </a>
          </li>
        {% endfor %}
      {% endif %}
      {# {% if collections.galerie %}
        {% for galeriePage in collections.galerie %}
          <li>
            <a href="{{ baseUrl }}{{ galeriePage.url }}" class="text-navigation hover:text-navigation-hover transition-colors {% if galeriePage.url == page.url %}text-navigation-active font-bold{% endif %}">
              {{ galeriePage.data.title }}
            </a>
          </li>
        {% endfor %}
      {% endif %} #}
    </ul>
  </div>
</nav>
