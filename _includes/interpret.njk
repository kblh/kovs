<!DOCTYPE html>
<html lang="cs">
  <head>
    <title>{{ name }} | Komorní orchestr Vlasty Škampové</title>
    {% include "_head.njk" %}
    <script defer src="{{ baseUrl }}/js/alpine.js?v={{ version or '1' }}"></script>
  </head>
  <body>

    {% include "navigation.njk" %}

    <article>

      {# ── HEADER ──────────────────────────────────────────────── #}
      <header class="border-b border-foreground/15">
        <div class="max-w-container-2xl mx-auto px-8 lg:px-16 py-8 lg:py-8">
          <div class="lg:grid lg:grid-cols-12 lg:gap-8 items-center">
            <div class="lg:col-start-2 {% if photo %}lg:col-span-6{% else %}lg:col-span-9{% endif %}">
              <p class="u-label mb-6 flex items-center gap-3">
                <span class="u-line"></span>
                Interpret
              </p>
              <h1 class="font-heading text-h1 leading-heading tracking-tight mb-3">
                {{ name }}
              </h1>
              {% if instrument %}
                <p class="text-muted text-lg uppercase tracking-time">
                  {{ instrument }}
                </p>
              {% endif %}
            </div>
            {% if photo %}
              <div class="mt-6 lg:mt-0 lg:col-span-3">
                <img src="{{ baseUrl }}/interpreti/img/{{ photo }}.jpg"
                     alt="{{ name }}"
                     class="w-full max-w-xs lg:max-w-none aspect-square object-cover rounded-full" />
              </div>
            {% endif %}
          </div>
        </div>
      </header>

      {# ── CONTENT ─────────────────────────────────────────────── #}
      {% if content %}
        <section class="border-b border-foreground/15">
          <div class="max-w-container-2xl mx-auto px-8 lg:px-16 py-8 lg:py-8">
            <div class="lg:grid lg:grid-cols-12 lg:gap-8">
              <div class="lg:col-start-2 lg:col-span-8 prose leading-relaxed space-y-5">
                {{ content | safe }}
              </div>
            </div>
          </div>
        </section>
      {% endif %}

    </article>
    {% include "footer.njk" %}
  </body>
</html>
