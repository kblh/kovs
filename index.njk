{% extends "_includes/default.njk" %}

{% block content %}

  {# ── HERO ──────────────────────────────────────────────────────── #}
  <section class="relative border-b border-foreground/15 overflow-hidden">
    <div class="max-w-container-2xl mx-auto px-8 lg:px-16 py-20 lg:py-20">
      <div class="lg:grid lg:grid-cols-12 lg:gap-8 items-end">

        <!-- Vertical label (desktop) -->
        <div class="hidden lg:flex lg:col-start-1 lg:col-span-1 items-end pb-2">
          <span class="text-muted text-micro uppercase tracking-label"
                style="writing-mode: vertical-rl; transform: rotate(180deg);">
            Praha / od roku 1994
          </span>
        </div>

        <!-- Main heading -->
        <div class="lg:col-start-2 lg:col-span-7">
          <p class="u-label mb-6 flex items-center gap-3">
            <span class="u-line"></span>
            Komorní orchestr
          </p>
          <h1 class="font-heading text-display leading-display tracking-tight  mb-8">
            Vlasty<br>
            <em class="not-italic text-accent">Škampové</em>
          </h1>
          <p class="text-muted text-base lg:text-lg max-w-xl leading-relaxed">
            Amatérský smyčcový orchestr sdružující hudebníky s bohatými zkušenostmi
            z Pražského studentského orchestru.
          </p>
        </div>

        <!-- Historic photo -->
        <div class="mt-12 lg:mt-0 lg:col-start-9 lg:col-span-4">
          <img
            src="{{ baseUrl }}/historie/pso_old.jpg"
            alt="Historická fotografie Pražského studentského orchestru"
            class="w-full h-auto shadow-lg"
            loading="lazy"
          />
        </div>

      </div>
    </div>
  </section>

  {# ── NÁSLEDUJÍCÍ KONCERT ───────────────────────────────────────── #}
  {% if collections.nextConcert[0] %}
    {% set nextConcert = collections.nextConcert[0] %}
    <section class="border-b border-foreground/15">
      <div class="max-w-container-2xl mx-auto px-8 lg:px-16 py-16 lg:py-16">
        <div class="lg:grid lg:grid-cols-12 lg:gap-8">
          <div class="lg:col-start-2 lg:col-span-10">

            <p class="u-label mb-8 flex items-center gap-3">
              <span class="u-line"></span>
              Následující koncert
            </p>

            <div class="border-t border-foreground pt-8 group">
              <a href="{{ baseUrl }}{{ nextConcert.url }}"
                 class="block hover:bg-background/50 transition-colors duration-500 -mx-4 px-4 py-2">
                <div class="flex flex-col lg:flex-row lg:items-baseline lg:justify-between gap-2">
                  <h2 class="font-heading text-3xl lg:text-4xl  group-hover:text-accent transition-colors duration-500">
                    {{ nextConcert.data.title }}
                  </h2>
                  {% if nextConcert.data.date %}
                    <time class="text-muted text-sm uppercase tracking-time"
                          datetime="{{ nextConcert.data.date }}">
                      {{ nextConcert.data.date | date }}
                    </time>
                  {% endif %}
                </div>
              </a>
            </div>

          </div>
        </div>
      </div>
    </section>
  {% endif %}

  {# ── VIDEO ─────────────────────────────────────────────────────── #}
  <section class="border-b border-foreground/15 bg-muted-bg">
    <div class="max-w-container-2xl mx-auto px-8 lg:px-16 py-16 lg:py-24">
      <div class="lg:grid lg:grid-cols-12 lg:gap-8">
        <div class="lg:col-start-2 lg:col-span-10">
          <p class="u-label mb-8 flex items-center gap-3">
            <span class="u-line"></span>
            Poslechnout
          </p>
          <div class="aspect-video shadow-lg">
            <iframe
              class="w-full h-full"
              src="https://www.youtube.com/embed/2H6P_g1G1Q8?si=vO6GfmdZcMolzTQr&amp;controls=0"
              title="YouTube video player"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen>
            </iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  {# ── O ORCHESTRU ───────────────────────────────────────────────── #}
  <section class="border-b border-foreground/15">
    <div class="max-w-container-2xl mx-auto px-8 lg:px-16 py-16 lg:py-32">
      <div class="lg:grid lg:grid-cols-12 lg:gap-8">

        <!-- Left label -->
        <div class="lg:col-span-3">
          <p class="u-label mb-6 flex items-center gap-3">
            <span class="u-line"></span>
            O orchestru
          </p>
        </div>

        <!-- Content -->
        <div class="lg:col-span-7">
          <h2 class="font-heading text-3xl lg:text-5xl  leading-tight mb-10">
            Hudba jako <em class="not-italic text-accent">vášeň</em>
          </h2>

          <div class="space-y-5  leading-relaxed max-w-2xl">
            <p>
              Komorní orchestr Vlasty Škampové je amatérský smyčcový orchestr, který vznikl
              počátkem roku 1994. Nese jméno po české dirigentce a klavíristce Vlastě Škampové
              (1937–1989), která po několik desetiletí řídila Pražský studentský orchestr.
            </p>
            <p>
              Orchestr je tvořen převážně amatérskými hudebníky, které spojuje neocenitelná
              zkušenost z mnohaletého působení v Pražském studentském orchestru. Členové orchestru
              mají nejrůznější povolání — jsou mezi nimi lékaři, pedagogové, inženýři, právníci,
              ekonomové, překladatelé — a hudbě se věnují ve svém volném čase.
            </p>
            <p>
              Orchestr často doprovází profesionální umělce a spolupracuje s pěveckými sbory,
              jako jsou Čeští madrigalisté, Canti di Praga, Collegium 419, Komorní sbor En Arché,
              plzeňský sbor Česká píseň či komorní pěvecký sbor z dánského Aarhusu.
            </p>
          </div>

          <div class="mt-12">
            {% if collections.koncerty %}
              <a href="{{ baseUrl }}/koncerty/" class="c-button">Přehled koncertů</a>
            {% endif %}
          </div>
        </div>

      </div>
    </div>
  </section>

  {# ── FOOTER CTA ────────────────────────────────────────────────── #}
  <footer class="bg-dark">
    <div class="max-w-container-2xl mx-auto px-8 lg:px-16 py-16 lg:py-24">
      <div class="lg:grid lg:grid-cols-12 lg:gap-8 items-end">
        <div class="lg:col-start-2 lg:col-span-8">
          <p class="text-micro uppercase tracking-label text-dark-fg/50 mb-6 flex items-center gap-3">
            <span class="block w-8 h-px bg-gold"></span>
            Kontakt
          </p>
          <h2 class="font-heading text-3xl lg:text-5xl text-dark-fg leading-tight mb-4">
            Přijďte nás poslouchat
          </h2>
          <p class="text-dark-fg/60 leading-relaxed mb-10 max-w-md">
            Sledujte naše koncerty a buďte u každého vystoupení.
          </p>
          {% if collections.koncerty %}
            <a href="{{ baseUrl }}/koncerty/" class="c-button">Nadcházející koncerty</a>
          {% endif %}
        </div>
        <div class="hidden lg:block lg:col-start-12 lg:col-span-1 text-right">
          <p class="text-micro text-dark-fg/25 uppercase tracking-button">
            © {{ "" | date("yyyy") }}
          </p>
        </div>
      </div>
    </div>
  </footer>

{% endblock %}
